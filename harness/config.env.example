# --- retry / exit conditions ---
MAX_RETRIES=3                  # per-issue Builder<->Verifier attempts
MAX_DIFF_LINES=400              # gate rejects oversized diffs -> needs-human
MAX_OPEN_AUTO_ISSUES=50         # Scanner stops filing past this backlog
MAX_ISSUES_PER_SCAN=8           # cap new issues filed in one scan run

# --- overseer thresholds ---
REJECT_RATE_WINDOW=10           # look at last N verifier verdicts
MAX_REJECT_RATE=0.5             # pause daemon if reject rate exceeds this
# daily_cycles now bumps once per LOOP_TICK_SECONDS heartbeat (not once per
# full scan/build/tune round like the old single-cadence loop), so this
# needs a correspondingly higher ceiling -- 3000 covers roughly a day of
# continuous 30s ticks with headroom, while still catching a genuinely
# stuck/runaway daemon.
MAX_DAILY_CYCLES=3000
MAX_DAILY_CLAUDE_CALLS=400
HALT_ON_HUMAN_REOPEN=true       # any human reopening a closed issue -> halt

# --- forbidden paths for gate.py (regex, pipe-separated) ---
FORBIDDEN_PATH_REGEX="migrations/|secrets/|\.github/workflows/|\.env$"

# --- cadence ---
# Each stage runs on its own interval, independent of the others, checked
# against a per-stage last-run time persisted in .harness/state.json (not
# an in-process counter, so cadence survives daemon restarts). The daemon
# wakes every LOOP_TICK_SECONDS and runs whichever stages are due.
LOOP_TICK_SECONDS=30             # base heartbeat
SCAN_INTERVAL_SECONDS=600        # Scanner: files new issues
TRIAGE_INTERVAL_SECONDS=120      # Triager: classify + auto-promote risk:low
BUILD_INTERVAL_SECONDS=60        # Builder/Verifier: check state:ready queue
TUNER_INTERVAL_SECONDS=7200      # Tuner: propose prompt/config refinements

REPO_DIR="."                    # path to the target repo (gh + git run here)
